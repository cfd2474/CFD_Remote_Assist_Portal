# Host nginx — dedicated Android device API (port 8448)
# Install: copy to /etc/nginx/sites-available/ on the Ubuntu host
# Uses the same TLS cert as the admin portal.

server {
    listen 8448 ssl;
    listen [::]:8448 ssl;
    server_name remote.tak-solutions.com;

    ssl_certificate /etc/letsencrypt/live/remote.tak-solutions.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/remote.tak-solutions.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 25m;

    location /api/v1/ {
        proxy_pass http://127.0.0.1:8091;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    location /ws/device {
        proxy_pass http://127.0.0.1:8091;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    location /health {
        proxy_pass http://127.0.0.1:8091;
        proxy_set_header Host $host;
    }

    location /version {
        proxy_pass http://127.0.0.1:8091;
        proxy_set_header Host $host;
    }
}
