# Host nginx — admin portal + OIDC (port 443)
# Install: copy to /etc/nginx/sites-available/ on the Ubuntu host
#
# Android device API is on port 8448 — see host-device-api.conf.example.
# Do not proxy /api/v1/ or /ws/device on 443.

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name remote.tak-solutions.com;

    ssl_certificate /etc/letsencrypt/live/remote.tak-solutions.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/remote.tak-solutions.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 25m;

    # Device API is on 8448 only
    location /api/v1/ {
        return 404;
    }

    location /ws/device {
        return 404;
    }

    location = /health {
        return 404;
    }

    location = /version {
        return 404;
    }

    location /auth/ {
        proxy_pass http://127.0.0.1:8092;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_read_timeout 300s;
    }

    location / {
        proxy_pass http://127.0.0.1:8091;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name remote.tak-solutions.com;
    return 301 https://$host$request_uri;
}
