# Database
POSTGRES_USER=cfd
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=cfd_remote_assist

# Public URL (used in device registration response & MDM config)
PUBLIC_BASE_URL=https://remote.example.com

# Authentik OIDC (Provider slug URL)
OIDC_ISSUER=https://auth.example.com/application/o/cfd-remote-assist/
OIDC_AUDIENCE=cfd-remote-assist
OIDC_CLIENT_ID=cfd-remote-assist
OIDC_JWKS_URI=

# Portal CORS (production portal origin)
CORS_ORIGIN=https://remote.example.com

# Ports exposed on host
HTTP_PORT=80
HTTPS_PORT=443
