# Database
POSTGRES_USER=cfd
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=cfd_remote_assist

# Public URL (device registration response & MDM tracking_server_url — include :8448 for device API)
PUBLIC_BASE_URL=https://remote.example.com:8448

# Authentik OIDC (provider slug URL)
OIDC_ISSUER=https://auth.example.com/application/o/cfd-remote-assist/
OIDC_AUDIENCE=cfd-remote-assist
OIDC_CLIENT_ID=cfd-remote-assist
# Required for Authentik (application JWKS path). Empty uses {issuer}/.well-known/jwks (may not work).
OIDC_JWKS_URI=https://auth.example.com/application/o/cfd-remote-assist/jwks/

# Admin Authorization (AT LEAST ONE IS REQUIRED)
# If neither is set, NO ONE will be able to log in or use admin endpoints (fails closed).
OIDC_ADMIN_GROUP=authentik Admins
# OIDC_ADMIN_EMAILS=admin@example.com,ops@example.com

# Portal CORS (admin portal origin — port 443, no device port)
CORS_ORIGIN=https://remote.example.com

# Docker nginx host bind (empty = all interfaces). infra-TAK / host-TLS: 127.0.0.1
NGINX_BIND_ADDR=

# HTTP port published on host (container listens on 80). infra-TAK uses 8767; standalone host nginx often uses 8091
HTTP_PORT=80

# Inner nginx is HTTP-only; TLS is terminated by host nginx or Caddy. See docs/infratak-integration.md
NGINX_ENABLE_TLS=false

# PhoneDB model lookup (set false if phonedb.net TLS verifies cleanly)
PHONEDB_TLS_INSECURE=true

# GitHub Releases — optional; default is unauthenticated lookup (Portal Configuration UI or .env)
GITHUB_APK_REPO=cfd2474/EUD_Remote_Assist_Portal
# GITHUB_TOKEN=
