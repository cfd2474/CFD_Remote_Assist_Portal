PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://cfd:cfd_secret@localhost:5432/cfd_remote_assist
OIDC_ISSUER=https://auth.example.com/application/o/cfd-remote-assist/
OIDC_AUDIENCE=cfd-remote-assist
OIDC_JWKS_URI=
CORS_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=https://remote.example.com
# Optional: GitHub repo for APK release lookup (owner/repo)
GITHUB_APK_REPO=cfd2474/EUD_Remote_Assist_Portal
# Optional: raises GitHub API rate limits for release lookups
GITHUB_TOKEN=
# PhoneDB uses an incomplete TLS chain; set true if model lookups fail
PHONEDB_TLS_INSECURE=true
